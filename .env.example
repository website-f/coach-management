SECRET_KEY=change-this-secret-key
DEBUG=false
ALLOWED_HOSTS=dashboard.example.com
CSRF_TRUSTED_ORIGINS=https://dashboard.example.com
ENABLE_HTTPS=true
DOMAIN=dashboard.example.com
WWW_DOMAIN=
LETSENCRYPT_EMAIL=admin@example.com
LETSENCRYPT_STAGING=false
NGINX_CLIENT_MAX_BODY_SIZE=20M

DB_ENGINE=mysql
DB_NAME=nyo_dashboard
DB_USER=nyo_user
DB_PASSWORD=change-this-db-password
DB_HOST=db
DB_PORT=3306
MYSQL_ROOT_PASSWORD=change-this-root-password

MEDIA_ROOT=/app/media
RUN_COLLECTSTATIC=1
AUTO_SEED_DATA=1

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=your-gmail@gmail.com
DEFAULT_REGISTRATION_FEE=120.00
DEFAULT_MONTHLY_FEE=180.00

SEED_ADMIN_PASSWORD=Admin123!
SEED_COACH_PASSWORD=Coach123!
SEED_HEADCOUNT_PASSWORD=Head123!
SEED_PARENT_PASSWORD=Parent123!
