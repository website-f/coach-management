upstream nyo_dashboard_upstream {
    server web:8000;
}

server {
    listen 80;
    server_name ${SERVER_NAMES};
    client_max_body_size ${NGINX_CLIENT_MAX_BODY_SIZE};

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        default_type text/plain;
        return 503 "HTTPS certificate provisioning is in progress. Please retry in a minute.\n";
    }
}
